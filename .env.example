# 火山引擎方舟 API Key (即梦AI 图片生成 4.0)
# 获取方式: 前往 https://console.volcengine.com/ark/ 开通即梦AI服务
# 在 "API Key 管理" 页面创建 API Key
ARK_API_KEY=your-ark-api-key-here

# 火山引擎方舟 API 地址 (无需修改)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 数据库地址 (SQLite 本地文件)
DATABASE_URL=sqlite+aiosqlite:///./vision_of_scale.db

# 生成图片存储目录
GENERATED_IMAGES_DIR=app/static/generated

# 默认模型
DEFAULT_MODEL=doubao-seedream-4-0-250828
